# PostgreSQL connection (khớp với docker-compose.yml)
DATABASE_URI=postgres://namduong:namduong@localhost:5432/namduongtea

# Payload secret (sinh chuỗi ngẫu nhiên 32+ ký tự)
PAYLOAD_SECRET=replace-with-long-random-string

# Public site URL (dùng cho SEO + canonical)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Payload public URL (mặc định = site URL)
NEXT_PUBLIC_PAYLOAD_URL=http://localhost:3000
