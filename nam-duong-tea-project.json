  "forms": {
    "quote_request": {
      "endpoint": "POST /api/public/quote-request",
      "fields": [
        { "name": "name", "label": "Họ tên", "required": true },
        { "name": "phone", "label": "Số điện thoại", "required": true },
        { "name": "email", "label": "Email", "required": false },
        { "name": "company", "label": "Công ty", "required": false },
        { "name": "quantity", "label": "Số lượng dự kiến", "required": true },
        { "name": "note", "label": "Ghi chú", "required": false }
      ],
      "optional_params": ["productSlug"],
      "success_title": "Đã nhận yêu cầu báo giá",
      "cms_collection": "quote-requests"
    },
    "agent_register": {
      "endpoint": "POST /api/public/contact",
      "body_type": "agent",
      "fields": [
        { "name": "name", "label": "Họ tên", "required": true },
        { "name": "phone", "label": "Số điện thoại", "required": true },
        { "name": "email", "label": "Email", "required": false },
        { "name": "company", "label": "Tên đơn vị", "required": true },
        { "name": "message", "label": "Tin nhắn", "required": false }
      ],
      "success_title": "Cảm ơn bạn!",
      "cms_collection": "contacts"
    },
    "newsletter": {
      "endpoint": "POST /api/public/newsletter"
    }
  },
  "cms": {
    "admin_path": "/admin",
    "collections": [
      {
        "slug": "users",
        "purpose": "Admin authentication"
      },
      {
        "slug": "media",
        "purpose": "Uploaded images/files"
      },
      {
        "slug": "categories",
        "fields": ["name", "slug", "description"]
      },
      {
        "slug": "products",
        "fields": [
          "name",
          "slug",
          "category",
          "shortDescription",
          "description",
          "image",
          "gallery",
          "specs",
          "moq",
          "origin",
          "isFeatured",
          "status",
          "seo"
        ],
        "status_values": ["draft", "published"]
      },
      {
        "slug": "posts",
        "fields": ["title", "slug", "excerpt", "coverImage", "body", "publishedAt", "status"]
      },
      {
        "slug": "contacts",
        "purpose": "Contact & agent registration"
      },
      {
        "slug": "quote-requests",
        "fields": ["name", "phone", "email", "company", "product", "quantity", "note", "status"],
        "status_values": ["new", "quoting", "won", "lost"]
      }
    ],
    "public_api": [
      "GET /api/public/products",
      "GET /api/public/products/[slug]",
      "POST /api/public/quote-request",
      "POST /api/public/contact",
      "POST /api/public/newsletter"
    ],
    "runtime_data_note": "products, posts, categories — export từ Payload admin hoặc DB khi cần đồng bộ đầy đủ"
  },
